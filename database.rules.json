{
  "rules": {
    ".read": false,
    ".write": false,

    "seminars": {
      ".read": true,
      ".indexOn": ["organizer", "type", "locationType", "startDate", "endDate", "createdAt"],
      "$seminar_id": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (newData.exists() && root.child('users').child(auth.uid).child('isVerified').val() === true && newData.child('organizer').val() === root.child('users').child(auth.uid).child('name').val() && (!data.exists() || data.child('organizer').val() === root.child('users').child(auth.uid).child('name').val())))",
        "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 150" },
        "organizer": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "description": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "location": { ".validate": "newData.isString() && newData.val().length <= 300" },
        "locationType": { ".validate": "newData.isString() && (newData.val() === 'physical' || newData.val() === 'online' || newData.val() === 'Physical' || newData.val() === 'Online' || newData.val() === 'Google Meet')" },
        "price": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "sessions": { ".validate": "newData.hasChildren()" },
        "$other": { ".validate": true }
      }
    },

    "trainers": {
      ".read": true,
      "$trainer_id": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true"
      }
    },

    "user_registrations": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
      }
    },

    "users": {
      ".read": "auth != null",
      ".indexOn": ["email", "username", "isVerified", "isAdmin", "isBanned"],
      "$uid": {
        ".read": "auth != null",
        "name": {
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "username": {
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "email": {
          ".write": "auth != null && ((auth.uid === $uid && (!data.exists() || newData.val() === data.val())) || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
          ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$/)"
        },
        "isAdmin": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (auth.uid === $uid && ((!data.exists() && newData.val() === false) || (data.exists() && newData.val() === data.val()))))",
          ".validate": "newData.isBoolean()"
        },
        "isVerified": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (auth.uid === $uid && ((!data.exists() && newData.val() === false) || (data.exists() && newData.val() === data.val()))))",
          ".validate": "newData.isBoolean()"
        },
        "isBanned": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (auth.uid === $uid && ((!data.exists() && newData.val() === false) || (data.exists() && newData.val() === data.val()))))",
          ".validate": "newData.isBoolean()"
        },
        "verificationRequested": {
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
          ".validate": "newData.isBoolean()"
        },
        "pfpUrl": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString()" },
        "bannerMode": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString() && (newData.val() === 'color' || newData.val() === 'gradient' || newData.val() === 'image')" },
        "bannerColor": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString()" },
        "bannerGradient": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString()" },
        "bannerImageUrl": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString()" },
        "roles": { ".write": "auth != null && auth.uid === $uid" },
        "faculties": { ".write": "auth != null && auth.uid === $uid" },
        "about": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString() && newData.val().length <= 2000" },
        "location": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString() && newData.val().length <= 120" },
        "experience": { ".write": "auth != null && auth.uid === $uid" },
        "certifications": { ".write": "auth != null && auth.uid === $uid" },
        "showExperience": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isBoolean()" },
        "showCertifications": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isBoolean()" },
        "createdAt": { ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)", ".validate": "newData.isNumber()" },
        "updatedAt": { ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)", ".validate": "newData.isNumber()" },
        "adminPasswordResetAt": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
          ".validate": "newData.isNumber()"
        },
        "adminPasswordResetBy": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
          ".validate": "newData.isString()"
        },
        "$other": { ".write": false, ".validate": false }
      }
    },

    "collections": {
      ".read": true,
      ".indexOn": ["creatorId", "category", "createdAt"],
      "$collection_id": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (root.child('users').child(auth.uid).child('isVerified').val() === true && newData.exists() && newData.child('creatorId').val() === auth.uid))",
        "title": { ".validate": "newData.isString() && newData.val().length <= 150" },
        "name": { ".validate": "newData.isString() && newData.val().length <= 150" },
        "description": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "category": { ".validate": "newData.isString()" },
        "priceType": { ".validate": "newData.isString() && (newData.val() === 'Free' || newData.val() === 'Paid')" },
        "price": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "creatorId": { ".validate": "newData.isString() && (newData.val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)" },
        "creatorName": { ".validate": "newData.isString()" },
        "fileUrl": { ".validate": false },
        "fileName": { ".validate": false },
        "$other": { ".validate": true }
      }
    },

    "collection_private": {
      "$collection_id": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || data.child('creatorId').val() === auth.uid || root.child('user_collections').child(auth.uid).child($collection_id).exists())",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('isAdmin').val() === true || (root.child('users').child(auth.uid).child('isVerified').val() === true && newData.exists() && newData.child('creatorId').val() === auth.uid))",
        "creatorId": { ".validate": "newData.isString() && (newData.val() === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "fileUrl": { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "fileName": { ".validate": "newData.isString() && newData.val().length <= 255" },
        "isDownloadable": { ".validate": "newData.isBoolean()" },
        "onlyViewInApp": { ".validate": "newData.isBoolean()" },
        "onlyViewableInApp": { ".validate": "newData.isBoolean()" },
        "$other": { ".validate": false }
      }
    },

    "user_collections": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
      }
    }
  }
}
