rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // User Profile Pictures (Images only, max 5MB, owner write)
    match /users/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && (fileName == 'profile_' + request.auth.uid || fileName.matches('profile_' + request.auth.uid + '_.*'))
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Profile media uploaded by the web profile editor.
    match /profile_media/{userId}/{folder}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Event/Seminar banners & posters (Images only, max 10MB)
    match /events/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /seminar_banners/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /seminar_posters/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Activity Attachments (files up to 50MB)
    match /activity_attachments/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Educational Collections Cover Images (Images up to 10MB)
    match /collection_covers/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Educational Collections Files (Documents/Slides up to 100MB)
    match /collection_files/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024;
    }

    // Default catch-all rule
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
